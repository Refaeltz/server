# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# Backend connection string (uses the service name "mongo" inside Docker)
MONGODB_URI=mongodb://admin:changeme@mongo:27017/app?authSource=admin

# JWT signing secret  →  openssl rand -hex 32
JWT_SECRET=changeme

# CORS allowed origin (set to your domain in production)
CORS_ORIGIN=http://localhost
